# ============ LLM ============
# Keep this true during development to use mock responses and avoid API costs.
# Switch to false for integration tests / demos / ablation experiments.
USE_MOCK_LLM=true

# DeepSeek by default (can also swap in Qwen / OpenAI / any OpenAI-compatible service)
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_TEMPERATURE=0.8

# ============ Embedding (local, no key required) ============
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ============ Ablation flags ============
USE_RAG=true
USE_MEMORY=true

# ============ Memory ============
SHORT_TERM_TURNS=5
SUMMARY_TRIGGER_TURNS=10

# ============ Retrieval ============
RETRIEVAL_TOP_K=3

# ============ World KB ============
WORLD_KB_PATH=world/world_kb.json
